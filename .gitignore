# Maven
hscode-matcher-api/target/
**/.flattened-pom.xml

# ONNX weights (GitHub max 100 MB per file; fetch from HuggingFace for local dev)
hscode-matcher-api/src/main/resources/onnx/*.onnx
hscode-matcher-api/src/test/resources/onnx/*.onnx

# Local embedding caches (generated; do not commit)
hscode-matcher-api/tmp/*.embedding-cache

# Bulk chapter-classify output (dev); keep .gitkeep
rest-client/out/*
!rest-client/out/.gitkeep

# IDE / OS
.idea/
*.iml
.DS_Store
Thumbs.db
